{
  "name": "auraos-runtime",
  "version": "1.0.0",
  "description": "AuraOS Agentic Runtime Environment Core Engine & CLI",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate:up": "tsx src/core/db/migrate.ts",
    "test:db": "tsx src/core/db/test-connection.ts",
    "test:unit": "tsx tests/unit/test-types-and-limits.ts",
    "test:integration": "tsx tests/integration/test-api-and-ws.ts",
    "test": "npm run test:unit && npm run test:integration"
  },
  "dependencies": {
    "dockerode": "^5.0.1",
    "dotenv": "^16.4.5",
    "node-cron": "^4.6.0",
    "pg": "^8.12.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.6",
    "@types/ws": "^8.18.1",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2"
  }
}
